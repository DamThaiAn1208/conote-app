<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.conote.client.controller.ColorPickerPopoverController"
      fx:id="root"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      managed="false"
      spacing="8.0"
      visible="false"
      StackPane.alignment="TOP_LEFT">
  <styleClass>
    <String fx:value="surface-shell" />
    <String fx:value="popover-card" />
  </styleClass>
  <StackPane.margin>
    <Insets left="54.0" top="58.0" />
  </StackPane.margin>
  <padding>
    <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
  </padding>
  <children>
    <FlowPane fx:id="colorFlow" hgap="10.0" vgap="10.0" />
  </children>
</VBox>
