<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.conote.client.controller.TextNoteEditorController"
      fx:id="root"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      styleClass="text-editor-shell">
  <children>
    <TextArea fx:id="editorArea"
              promptText="Start writing your note..."
              styleClass="text-note-editor"
              VBox.vgrow="ALWAYS"
              wrapText="true" />
  </children>
</VBox>
