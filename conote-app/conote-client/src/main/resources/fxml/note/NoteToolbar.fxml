<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane fx:controller="com.conote.client.controller.NoteToolbarController"
           fx:id="root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           alignment="BOTTOM_LEFT"
           maxHeight="1.7976931348623157E308"
           maxWidth="74.0"
           minWidth="74.0"
           pickOnBounds="false"
           prefWidth="74.0"
            styleClass="note-toolbar-shell">
  <children>
    <AnchorPane pickOnBounds="false" StackPane.alignment="TOP_LEFT">
      <children>
        <VBox fx:id="toolRail"
              alignment="TOP_CENTER"
              maxHeight="1.7976931348623157E308"
              maxWidth="56.0"
              minWidth="56.0"
              prefWidth="56.0"
              spacing="10.0"
              styleClass="note-toolbar-panel"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.topAnchor="0.0">
          <padding>
            <Insets bottom="42.0" left="8.0" right="8.0" top="10.0" />
          </padding>
          <children>
            <VBox fx:id="formattingGroup" alignment="TOP_CENTER" spacing="8.0">
              <children>
                <ToggleButton fx:id="boldToggle"
                              mnemonicParsing="false"
                              onAction="#toggleBold">
                  <styleClass>
                    <String fx:value="note-side-tool-button" />
                    <String fx:value="note-side-tool-icon-button" />
                  </styleClass>
                  <graphic>
                    <FontIcon iconLiteral="fas-bold:13" styleClass="note-format-icon" />
                  </graphic>
                </ToggleButton>
                <ToggleButton fx:id="italicToggle"
                              mnemonicParsing="false"
                              onAction="#toggleItalic">
                  <styleClass>
                    <String fx:value="note-side-tool-button" />
                    <String fx:value="note-side-tool-icon-button" />
                  </styleClass>
                  <graphic>
                    <FontIcon iconLiteral="fas-italic:13" styleClass="note-format-icon" />
                  </graphic>
                </ToggleButton>
                <ToggleButton fx:id="underlineToggle"
                              mnemonicParsing="false"
                              onAction="#toggleUnderline">
                  <styleClass>
                    <String fx:value="note-side-tool-button" />
                    <String fx:value="note-side-tool-icon-button" />
                  </styleClass>
                  <graphic>
                    <FontIcon iconLiteral="fas-underline:13" styleClass="note-format-icon" />
                  </graphic>
                </ToggleButton>
                <ToggleButton fx:id="strikethroughToggle"
                              mnemonicParsing="false"
                              onAction="#toggleStrikethrough">
                  <styleClass>
                    <String fx:value="note-side-tool-button" />
                    <String fx:value="note-side-tool-icon-button" />
                  </styleClass>
                  <graphic>
                    <FontIcon iconLiteral="fas-strikethrough:13" styleClass="note-format-icon" />
                  </graphic>
                </ToggleButton>
              </children>
            </VBox>
          </children>
        </VBox>
        <Button fx:id="sidebarToggleButton"
                mnemonicParsing="false"
                onAction="#toggleSidebar"
                styleClass="note-sidebar-toggle-button"
                AnchorPane.bottomAnchor="10.0"
                AnchorPane.leftAnchor="56.0">
          <graphic>
            <FontIcon fx:id="sidebarToggleIcon"
                      iconLiteral="codicon-chevron-left:14"
                      styleClass="note-sidebar-toggle-icon" />
          </graphic>
        </Button>
      </children>
    </AnchorPane>
  </children>
</StackPane>
