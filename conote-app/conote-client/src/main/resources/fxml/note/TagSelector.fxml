<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.conote.client.controller.TagSelectorController"
      fx:id="root"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      managed="false"
      spacing="10.0"
      visible="false"
      StackPane.alignment="TOP_LEFT">
  <styleClass>
    <String fx:value="surface-shell" />
    <String fx:value="popover-card" />
  </styleClass>
  <StackPane.margin>
    <Insets left="98.0" top="58.0" />
  </StackPane.margin>
  <padding>
    <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
  </padding>
  <children>
    <HBox spacing="8.0">
      <children>
        <TextField fx:id="tagField" promptText="Add a tag..." styleClass="popover-input" HBox.hgrow="ALWAYS" />
        <Button mnemonicParsing="false" onAction="#addTag" styleClass="primary-compact-button" text="Add" />
      </children>
    </HBox>
    <VBox spacing="8.0">
      <children>
        <Label styleClass="section-kicker" text="SELECTED TAGS" />
        <FlowPane fx:id="currentTagsFlow" hgap="8.0" vgap="8.0" />
      </children>
    </VBox>
    <VBox spacing="8.0">
      <children>
        <Label styleClass="section-kicker" text="AVAILABLE TAGS" />
        <FlowPane fx:id="availableTagsFlow" hgap="8.0" vgap="8.0" />
      </children>
    </VBox>
  </children>
</VBox>
