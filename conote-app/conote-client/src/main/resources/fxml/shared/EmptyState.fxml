<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane fx:controller="com.conote.client.controller.EmptyStateController"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="empty-state-shell">
  <children>
    <VBox alignment="CENTER" spacing="10.0" styleClass="empty-state-content">
      <children>
        <FontIcon iconLiteral="codicon-note:28" styleClass="empty-state-icon" />
        <Label styleClass="empty-state-title" text="No matching notes" />
        <Label styleClass="empty-state-copy"
               text="Try changing your filters or create a fresh note to start capturing ideas."
               wrapText="true" />
        <Button mnemonicParsing="false" onAction="#createFirstNote" styleClass="inline-link-button" text="Create your first note" />
      </children>
    </VBox>
  </children>
</StackPane>
