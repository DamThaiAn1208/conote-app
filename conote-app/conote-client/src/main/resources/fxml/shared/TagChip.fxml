<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox fx:controller="com.conote.client.controller.TagChipController"
      fx:id="root"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER_LEFT"
      spacing="4.0"
      styleClass="tag-chip">
  <children>
    <Label fx:id="textLabel" styleClass="tag-chip-label" text="#tag" />
    <Button fx:id="removeButton" managed="false" mnemonicParsing="false" styleClass="tag-chip-remove" visible="false">
      <graphic>
        <FontIcon iconLiteral="codicon-close:10" styleClass="chip-remove-icon" />
      </graphic>
    </Button>
  </children>
</HBox>
