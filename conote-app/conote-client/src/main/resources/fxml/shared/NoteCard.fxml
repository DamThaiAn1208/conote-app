<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:controller="com.conote.client.controller.NoteCardController"
      fx:id="root"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      onMouseClicked="#handleCardClick"
      spacing="10.0"
      styleClass="note-card">
  <padding>
    <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
  </padding>
  <children>
    <HBox alignment="TOP_LEFT" spacing="8.0">
      <children>
        <Label fx:id="titleLabel" styleClass="note-card-title" text="Note title" HBox.hgrow="ALWAYS" />
        <TextField fx:id="titleField" managed="false" styleClass="note-card-title-field" visible="false" HBox.hgrow="ALWAYS" />
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER_RIGHT" spacing="6.0" styleClass="note-card-actions">
          <children>
            <Button fx:id="pinButton" managed="false" mnemonicParsing="false" onAction="#togglePin" styleClass="note-icon-button" visible="false" />
            <Button fx:id="openWindowButton" managed="false" mnemonicParsing="false" onAction="#openNoteWindow" styleClass="note-icon-button" visible="false">
              <graphic>
                <FontIcon iconLiteral="codicon-link-external:15" styleClass="card-action-icon" />
              </graphic>
            </Button>
          </children>
        </HBox>
      </children>
    </HBox>
    <StackPane fx:id="textContentStack" managed="false" visible="false">
      <children>
        <Label fx:id="previewLabel" styleClass="note-card-preview" text="Preview" wrapText="true" StackPane.alignment="TOP_LEFT" />
        <TextFlow fx:id="richPreviewFlow" managed="false" visible="false" StackPane.alignment="TOP_LEFT" />
        <VBox fx:id="richTextEditorBox" managed="false" visible="false" StackPane.alignment="TOP_LEFT" />
        <VBox fx:id="textEditorBox" managed="false" visible="false" StackPane.alignment="TOP_LEFT">
          <children>
            <TextArea fx:id="quickTextArea" prefRowCount="3" styleClass="quick-note-textarea" wrapText="true" />
          </children>
        </VBox>
      </children>
    </StackPane>
    <VBox fx:id="checklistPreviewBox" managed="false" spacing="8.0" visible="false" />
    <StackPane fx:id="expandedContainer" managed="false" maxHeight="0.0" opacity="0.0" visible="false">
      <children>
        <VBox fx:id="expandedContent" spacing="10.0" styleClass="expanded-card-body">
          <children>
            <VBox fx:id="checklistEditorBox" managed="false" spacing="8.0" visible="false">
              <children>
                <VBox fx:id="checklistItemsBox" spacing="8.0" />
                <Button fx:id="addChecklistItemButton" mnemonicParsing="false" onAction="#addChecklistItem" styleClass="inline-link-button" text="+ Add item" />
              </children>
            </VBox>
          </children>
        </VBox>
      </children>
    </StackPane>
    <VBox spacing="4.0" styleClass="note-card-meta">
      <children>
        <FlowPane fx:id="tagsFlow" hgap="8.0" vgap="8.0" />
        <HBox alignment="CENTER_RIGHT" styleClass="note-card-date-row">
          <children>
            <Region HBox.hgrow="ALWAYS" />
            <HBox fx:id="sharedSourceBadge"
                  alignment="CENTER"
                  managed="false"
                  maxWidth="96.0"
                  spacing="3.0"
                  styleClass="note-source-badge"
                  visible="false">
              <children>
                <FontIcon iconLiteral="codicon-account:11" styleClass="note-source-badge-icon" />
                <Label fx:id="sharedSourceLabel"
                       maxWidth="72.0"
                       styleClass="note-source-badge-label"
                       text="Trần Minh" />
              </children>
            </HBox>
            <Label fx:id="dateLabel" styleClass="note-card-date" text="Apr 17" />
          </children>
        </HBox>
      </children>
    </VBox>
  </children>
</VBox>
