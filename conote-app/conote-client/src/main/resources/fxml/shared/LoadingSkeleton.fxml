<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.conote.client.controller.LoadingSkeletonController"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="12.0"
      styleClass="loading-shell">
  <padding>
    <Insets bottom="16.0" left="12.0" right="12.0" top="12.0" />
  </padding>
  <children>
    <Region prefHeight="120.0" styleClass="skeleton-card" />
    <Region prefHeight="110.0" styleClass="skeleton-card" />
    <Region prefHeight="140.0" styleClass="skeleton-card" />
  </children>
</VBox>
