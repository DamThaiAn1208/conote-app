<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.conote.client.controller.FilterPanelController"
      fx:id="root"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      managed="false"
      spacing="14.0"
      visible="false">
  <styleClass>
    <String fx:value="surface-shell" />
    <String fx:value="filter-panel" />
  </styleClass>
  <children>
    <VBox spacing="8.0">
      <children>
        <Label styleClass="section-kicker" text="SORT" />
        <ComboBox fx:id="sortCombo" prefWidth="160.0" styleClass="filter-combo" />
      </children>
    </VBox>
    <VBox spacing="8.0">
      <children>
        <Label styleClass="section-kicker" text="COLOR" />
        <FlowPane fx:id="colorFlow" hgap="10.0" vgap="10.0" />
      </children>
    </VBox>
    <VBox spacing="8.0">
      <children>
        <Label styleClass="section-kicker" text="TAGS" />
        <FlowPane fx:id="tagFlow" hgap="8.0" vgap="8.0" />
      </children>
    </VBox>
  </children>
</VBox>
